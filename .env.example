NODE_ENV=development
PORT=4000
API_PREFIX=/api

DATABASE_URL=postgres://evoting:evoting_password@localhost:5432/evoting

CORS_ORIGIN=*
LOG_LEVEL=info
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

# pow, pos, or pbft
CONSENSUS_ALGORITHM=pow
POW_DIFFICULTY=3
APP_VOTE_POW_DIFFICULTY=2
MINING_REWARD=10
MAX_TRANSACTIONS_PER_BLOCK=100

# Set true in containers if you want the API process to apply schema.sql at startup.
AUTO_MIGRATE=false
NEXT_PUBLIC_AUTH_BYPASS=false
JWT_SECRET=change-this-long-random-jwt-secret-before-production
CHAIN_SECRET=change-this-long-random-vote-signing-secret-before-production
